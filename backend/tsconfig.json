{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": false,
    "jsx": "preserve",
    "paths": {
      "@ace/shared": ["../frontend/shared/src/index.ts"],
      "@ace/shared/*": ["../frontend/shared/src/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "vitest.config.ts"]
}
